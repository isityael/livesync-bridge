{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>m0sh1/infra//.github/renovate/base.json",
    "config:best-practices",
    ":preserveSemverRanges"
  ],
  "enabledManagers": ["dockerfile", "github-actions", "woodpecker", "npm"],
  "packageRules": [
    {
      "description": "Keep the ESLint compatibility compiler on TypeScript 6",
      "matchDepNames": ["typescript-eslint-compiler"],
      "enabled": false
    },
    {
      "matchManagers": ["dockerfile"],
      "addLabels": ["docker"]
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["ci"]
    },
    {
      "description": "Group all GitHub Actions into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Auto-merge Node package patch and minor updates — low blast radius",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "minimumReleaseAge": "1 day",
      "automerge": true
    }
  ]
}
