{
  "name": "livesync-bridge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=26 <27",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "rm -rf dist coverage",
    "fmt:check": "prettier --check .github/renovate.json .github/workflows/publish-ghcr.yaml .woodpecker/build.yaml .woodpecker/release.yaml package.json tsconfig.json eslint.config.js vitest.config.ts scripts/build.mjs runtime/node_compat.ts stubs/*.ts test/*.ts main.ts Peer.ts PeerStorage.ts readme.md",
    "lint": "eslint *.ts stubs/*.ts runtime/*.ts test/*.ts vitest.config.ts",
    "start": "node dist/main.js",
    "test": "pnpm run build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@smithy/md5-js": "^4.4.1",
    "@smithy/middleware-apply-body-checksum": "^4.5.1",
    "@smithy/types": "^4.15.0",
    "@smithy/util-retry": "^4.5.1",
    "@trystero-p2p/nostr": "^0.25.2",
    "brace-expansion": "^5.0.6",
    "chokidar": "^5.0.0",
    "diff": "^9.0.0",
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "markdown-it": "^14.2.0",
    "minimatch": "^10.2.5",
    "octagonal-wheels": "^0.1.46",
    "pouchdb-adapter-http": "^9.0.0",
    "pouchdb-adapter-idb": "^9.0.0",
    "pouchdb-adapter-indexeddb": "^9.0.0",
    "pouchdb-adapter-memory": "^9.0.0",
    "pouchdb-core": "^9.0.0",
    "pouchdb-errors": "^9.0.0",
    "pouchdb-find": "^9.0.0",
    "pouchdb-mapreduce": "^9.0.0",
    "pouchdb-merge": "^9.0.0",
    "pouchdb-replication": "^9.0.0",
    "pouchdb-utils": "^9.0.0",
    "qrcode-generator": "^2.0.4",
    "transform-pouch": "^2.0.0",
    "trystero": "^0.21.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.0",
    "@types/pouchdb": "^6.4.2",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
